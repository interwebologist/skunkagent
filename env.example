# LLM Server Configuration
# Copy this file to .env and fill in your actual values

# OpenAI-compatible API endpoint for local LLM server
OPENAI_API_BASE=http://192.168.1.33:8080/v1

# API key (set to "not-needed" for local servers that don't require authentication)
OPENAI_API_KEY=not-needed

# Optional: Model name override
# MODEL_NAME=NVIDIA-Nemotron-3-Super-120B-A12B-UD-Q4_K_XL.gguf

# Search API Configuration
SERPBASE_API_KEY=your_serpbase_api_key_here